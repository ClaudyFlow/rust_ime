    },
    "switch_language_alt": {
      "key": "ctrl+space",
      "description": "核心: 切换中/英文模式 (备选)"
    },
    "switch_dictionary": {
      "key": "ctrl+alt+s",
      "description": "功能: 切换输入方案/词库"
    },
    "cycle_preview_mode": {
      "key": "ctrl+alt+p",
      "description": "界面: 切换屏幕预览模式"
    },
    "toggle_notifications": {
      "key": "ctrl+alt+n",
      "description": "界面: 开启/关闭系统通知"
    },
    "cycle_paste_method": {
      "key": "ctrl+alt+v",
      "description": "兼容: 切换粘贴注入方式"
    },
    "toggle_traditional_gui": {
      "key": "ctrl+alt+g",
      "description": "界面: 显示/隐藏传统候选窗"
    },
    "toggle_modern_gui": {
      "key": "ctrl+alt+h",
      "description": "界面: 显示/隐藏卡片候选词"
    },
    "toggle_keystrokes": {
      "key": "ctrl+alt+k",
      "description": "功能: 开启/关闭按键显示"
    },
