{
  "files": {
    "punctuation_file": "dicts/chinese/punctuation.json",
    "profiles": [
      {
        "name": "chinese",
        "path": "data/chinese/trie"
      },
      {
        "name": "english",
        "path": "data/english/trie"
      },
      {
        "name": "japanese",
        "path": "data/japanese/trie"
      }
    ]
  },
  "appearance": {
    "show_candidates": true,
    "show_modern_candidates": true,
    "show_notifications": false,
    "show_keystrokes": false,
    "page_size": 5,
    "show_tone_hint": false,
    "show_en_hint": true,
    "candidate_anchor": "bottom",
    "candidate_font_size": 18,
    "candidate_hint_font_size": 10,
    "candidate_margin_x": 0,
    "candidate_margin_y": 50,
    "candidate_bg_color": "#f6f5f4",
    "candidate_text_color": "#000000",
    "candidate_highlight_color": "#0071e3",
    "modern_cand_anchor": "bottom_left",
    "modern_cand_font_size": 16,
    "modern_cand_hint_font_size": 10,
    "modern_cand_margin_x": 40,
    "modern_cand_margin_y": 200,
    "modern_cand_text_color": "#0071e3",
    "modern_cand_highlight_color": "#0071e3",
    "modern_cand_bg_color": "rgba(255, 255, 255, 0.95)",
    "keystroke_anchor": "bottom_right",
    "keystroke_font_size": 24,
    "keystroke_timeout_ms": 1500,
    "keystroke_bg_color": "rgba(0, 0, 0, 0.7)",
    "keystroke_margin_x": 20,
    "keystroke_margin_y": 20,
    "learning_mode": false,
    "learning_anchor": "top_right",
    "learning_interval_sec": 10,
    "learning_font_size": 24,
    "learning_margin_x": 20,
    "learning_margin_y": 40,
    "learning_bg_color": "rgba(20, 20, 20, 0.85)",
    "learning_dict_path": "dicts/chinese/words/words.json",
    "preview_mode": "pinyin",
    "learning_interval": 10
  },
  "input": {
    "autostart": false,
    "commit_mode": "single",
    "default_profile": "chinese",
    "paste_method": "shift_insert",
    "clipboard_delay_ms": 10,
    "enable_anti_typo": true,
    "enable_quick_rime": true,
    "quick_rimes": [
      {
        "trigger": "caps+j",
        "insert": "iang"
      },
      {
        "trigger": "caps+k",
        "insert": "uai"
      },
      {
        "trigger": "caps+l",
        "insert": "uang"
      },
      {
        "trigger": "caps+i",
        "insert": "ing"
      },
      {
        "trigger": "caps+o",
        "insert": "ong"
      },
      {
        "trigger": "caps+p",
        "insert": "un"
      },
      {
        "trigger": "caps+n",
        "insert": "ian"
      },
      {
        "trigger": "caps+m",
        "insert": "ian"
      },
      {
        "trigger": "caps+u",
        "insert": "sh"
      },
      {
        "trigger": "caps+a",
        "insert": "ch"
      },
      {
        "trigger": "caps+e",
        "insert": "zh"
      },
      {
        "trigger": "caps+z",
        "insert": "ou"
      },
      {
        "trigger": "caps+c",
        "insert": "ao"
      },
      {
        "trigger": "caps+s",
        "insert": "ai"
      }
    ],
    "auto_commit_unique_en_fuzhuma": false,
    "auto_commit_unique_full_match": false,
    "enable_prefix_matching": true,
    "prefix_matching_limit": 20,
    "enable_abbreviation_matching": true,
    "filter_proper_nouns_by_case": true,
    "active_profiles": [
      "chinese"
    ],
    "profile_keys": [],
    "page_flipping_keys": [
      "arrow"
    ],
    "enable_error_sound": true
  },
  "hotkeys": {
    "switch_language": {
      "key": "tab",
      "description": "核心: 切换中/英文模式"
    },
    "switch_language_alt": {
      "key": "ctrl+space",
      "description": "核心: 切换中/英文模式 (备选)"
    },
    "switch_dictionary": {
      "key": "ctrl+alt+s",
      "description": "功能: 切换输入方案/词库"
    },
    "cycle_preview_mode": {
      "key": "ctrl+alt+p",
      "description": "界面: 切换屏幕预览模式"
    },
    "toggle_notifications": {
      "key": "ctrl+alt+n",
      "description": "界面: 开启/关闭系统通知"
    },
    "cycle_paste_method": {
      "key": "ctrl+alt+v",
      "description": "兼容: 切换粘贴注入方式"
    },
    "toggle_traditional_gui": {
      "key": "ctrl+alt+g",
      "description": "界面: 显示/隐藏传统候选窗"
    },
    "toggle_modern_gui": {
      "key": "ctrl+alt+h",
      "description": "界面: 显示/隐藏卡片候选词"
    },
    "toggle_keystrokes": {
      "key": "ctrl+alt+k",
      "description": "功能: 开启/关闭按键显示"
    },
    "switch_commit_mode": {
      "key": "ctrl+alt+m",
      "description": "模式: 切换单/双空格上屏"
    }
  }
}