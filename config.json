{
  "_help_readme": "本配置文件已优化。请修改 'key' 字段来更改快捷键。'paste_method' 可选值: ctrl_v, ctrl_shift_v, shift_insert",
  "appearance": {
    "show_notifications": true,
    "preview_mode": "pinyin",
    "show_candidates": false,
    "show_modern_candidates": false,
    "show_keystrokes": false,
    "candidate_anchor": "bottom",
    "candidate_margin_x": 100,
    "candidate_margin_y": 120,
    "candidate_bg_color": "rgba(20, 20, 20, 0.85)",
    "candidate_font_size": 14,
    "modern_cand_anchor": "bottom_left",
    "modern_cand_margin_x": 40,
    "modern_cand_margin_y": 200,
    "modern_cand_bg_color": "rgba(10, 10, 10, 0.95)",
    "modern_cand_text_color": "#2ecc71",
    "modern_cand_font_size": 16,
    "keystroke_anchor": "bottom_right",
    "keystroke_margin_x": 40,
    "keystroke_margin_y": 120,
    "keystroke_bg_color": "rgba(20, 20, 20, 0.85)",
    "keystroke_font_size": 11,
    "keystroke_timeout_ms": 1000,
    "learning_mode": true,
    "learning_interval_sec": 10,
    "learning_dict_path": "dicts/chinese/chars.json"
  },
  "input": {
    "enable_fuzzy_pinyin": false,
    "autostart": false,
    "default_profile": "chinese",
    "paste_method": "ctrl_v",
    "clipboard_delay_ms": 50,
    "enable_anti_typo": true,
    "commit_mode": "single",
    "quick_rimes": [
      {
        "trigger": "tab+g",
        "insert": "eng"
      },
      {
        "trigger": "tab+h",
        "insert": "ang"
      },
      {
        "trigger": "tab+j",
        "insert": "iang"
      },
      {
        "trigger": "tab+k",
        "insert": "uai"
      },
      {
        "trigger": "tab+l",
        "insert": "uang"
      },
      {
        "trigger": "tab+i",
        "insert": "ing"
      },
      {
        "trigger": "tab+o",
        "insert": "ong"
      },
      {
        "trigger": "tab+p",
        "insert": "iong"
      },
      {
        "trigger": "tab+n",
        "insert": "iao"
      },
      {
        "trigger": "tab+m",
        "insert": "ian"
      },
      {
        "trigger": "tab+u",
        "insert": "uan"
      }
    ],
    "enable_quick_rime": true,
    "enable_error_sound": true
  },
  "hotkeys": {
    "switch_language": {
      "key": "caps_lock",
      "description": "核心: 切换中/英文模式"
    },
    "switch_language_alt": {
      "key": "ctrl+space",
      "description": "核心: 切换中/英文模式 (备选)"
    },
    "cycle_preview_mode": {
      "key": "ctrl+alt+p",
      "description": "功能: 切换输入预览模式 (无 -> 拼音 -> 汉字)"
    },
    "toggle_notifications": {
      "key": "ctrl+alt+n",
      "description": "功能: 开启/关闭桌面候选词通知"
    },
    "switch_dictionary": {
      "key": "ctrl+alt+s",
      "description": "功能: 切换词库 (如 中文 -> 日语)"
    },
    "cycle_paste_method": {
      "key": "ctrl+alt+v",
      "description": "高级: 循环切换自动粘贴的方式 (如在终端无法上屏时使用)"
    },
    "trigger_caps_lock": {
      "key": "caps_lock+tab",
      "description": "高级: 发送真实的 CapsLock 键 (因 CapsLock 被占用于切换输入法)"
    },
    "toggle_traditional_gui": {
      "key": "ctrl+alt+g",
      "description": "功能: 显示/隐藏 传统候选窗"
    },
    "toggle_modern_gui": {
      "key": "ctrl+alt+h",
      "description": "功能: 显示/隐藏 卡片式候选词"
    },
    "toggle_keystrokes": {
      "key": "ctrl+alt+k",
      "description": "功能: 显示/隐藏 按键显示"
    },
    "switch_commit_mode": {
      "key": "ctrl+alt+m",
      "description": "功能: 切换上屏模式 (词模式/长句模式)"
    }
  },
  "files": {
    "device_path": null,
    "profiles": [
      {
        "name": "Chinese",
        "description": "默认中文输入",
        "dicts": [
          "dicts/chars.json",
          "dicts/basic_words.json"
        ]
      },
      {
        "name": "English",
        "description": "英文输入方案",
        "dicts": [
          "dicts/english"
        ]
      },
      {
        "name": "Japanese",
        "description": "日语输入方案",
        "dicts": [
          "dicts/japanese"
        ]
      }
    ],
    "punctuation_file": "dicts/punctuation.json",
    "char_defs": []
  }
}