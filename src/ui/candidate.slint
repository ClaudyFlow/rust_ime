export component CandidateWindow inherits Window {
    // 状态数据
    in property <string> pinyin;
    in property <[string]> candidates;
    in property <int> selected_index: 0;
    in property <bool> is_visible: false;

    // 窗口属性
    no-frame: true;
    background: transparent;
    always-on-top: true;
    
    // 样式常量
    property <length> border_radius: 8px;
    property <color> bg_color: #f5f5f5;
    property <color> accent_color: #3498db;
    property <color> text_color: #333333;
    property <color> highlight_text_color: #ffffff;

    Rectangle {
        visible: is_visible;
        background: bg_color;
        border-radius: border_radius;
        border-width: 1px;
        border-color: #dddddd;
        drop-shadow-blur: 8px;
        drop-shadow-color: rgba(0, 0, 0, 0.2);

        VerticalLayout {
            padding: 8px;
            spacing: 6px;

            // 拼音显示栏
            if pinyin != "" : Text {
                text: pinyin;
                color: #666666;
                font-size: 14px;
                horizontal-alignment: left;
            }

            // 5 个候选词列表
            VerticalLayout {
                spacing: 4px;
                for cand[i] in candidates : Rectangle {
                    height: 32px;
                    background: i == selected_index ? accent_color : transparent;
                    border-radius: 4px;

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 8px;
                        
                        // 序号
                        Text {
                            text: (i + 1) + ".";
                            color: i == selected_index ? highlight_text_color : #999999;
                            vertical-alignment: center;
                            font-size: 16px;
                        }
                        
                        // 候选词文本
                        Text {
                            text: cand;
                            color: i == selected_index ? highlight_text_color : text_color;
                            vertical-alignment: center;
                            font-size: 18px;
                            font-weight: i == selected_index ? 600 : 400;
                        }
                    }
                }
            }
        }
    }
}
