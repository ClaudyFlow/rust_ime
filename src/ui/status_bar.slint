export component StatusBar inherits Window {
    title: "RustImeStatusBar";
    in property <string> status_text: "中";
    in property <bool> chinese_enabled: true;

    no-frame: true;
    background: transparent;
    always-on-top: true;
    
    width: 40px;
    height: 26px;

    Rectangle {
        width: 100%;
        height: 100%;
        background: chinese_enabled ? #0969da : #586069;
        border-radius: 4px; // 矩形加圆角
        
        // 阴影效果
        drop-shadow-blur: 4px;
        drop-shadow-color: rgba(0, 0, 0, 0.2);
        drop-shadow-offset-y: 1px;

        Text {
            text: status_text;
            color: white;
            font-size: 14px;
            font-weight: 800;
            // 确保绝对居中
            horizontal-alignment: center;
            vertical-alignment: center;
            width: 100%;
            height: 100%;
        }
    }
}
