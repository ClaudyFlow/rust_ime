export component StatusBar inherits Window {
    title: "RustImeStatusBar";
    in property <string> status_text: "中";
    in property <bool> chinese_enabled: true;

    no-frame: true;
    background: transparent;
    always-on-top: true;
    
    width: 32px;
    height: 32px;

    Rectangle {
        width: 100%;
        height: 100%;
        background: chinese_enabled ? #0969da : #586069;
        border-radius: 16px; // 圆形
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.2);
        
        // 阴影效果
        drop-shadow-blur: 4px;
        drop-shadow-color: rgba(0, 0, 0, 0.3);
        drop-shadow-offset-y: 2px;

        Text {
            text: status_text;
            color: white;
            font-size: 14px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // 悬停反馈（如果需要）
    states [
        active when chinese_enabled : {
            background: #0969da;
        }
        inactive when !chinese_enabled : {
            background: #586069;
        }
    ]
}
